{
  "manifest_version": 3,
  "name": "Meridian",
  "version": "1.0.0",
  "description": "A beautiful multi-timezone new tab page. See the time of day across the world in color.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
